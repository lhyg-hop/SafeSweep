<Window x:Class="SafeSweep.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:models="clr-namespace:SafeSweep.Models"
        xmlns:viewModels="clr-namespace:SafeSweep.ViewModels"
        mc:Ignorable="d"
        Title="SafeSweep 空间治理助手"
        Width="1450"
        Height="920"
        MinWidth="1100"
        MinHeight="700"
        Background="#FFF4F1E8">
  <Grid Margin="20">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <Border Padding="18"
            Background="#FF1F3A5F"
            CornerRadius="18">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>
        <StackPanel>
          <TextBlock FontSize="28"
                     FontWeight="SemiBold"
                     Foreground="White"
                     Text="SafeSweep" />
          <TextBlock Margin="0,8,0,0"
                     FontSize="14"
                     Foreground="#FFE6EEF7"
                     Text="先解释，再处理；可恢复，比清得更狠更重要。" />
          <TextBlock Margin="0,10,0,0"
                     FontSize="13"
                     Foreground="#FFD7E3F4"
                     Text="{Binding StatusText}" />
        </StackPanel>

        <StackPanel Grid.Column="1"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center">
          <CheckBox Margin="0,0,16,0"
                    VerticalAlignment="Center"
                    Foreground="White"
                    IsChecked="{Binding PreferImmediateFreeSpace}"
                    Content="如果没有非系统盘隔离区，优先直接释放空间" />
          <Button Margin="0,0,8,0"
                  Padding="14,8"
                  Command="{Binding QuickScanCommand}"
                  Content="快速扫描" />
          <Button Margin="0,0,8,0"
                  Padding="14,8"
                  Command="{Binding DeepScanCommand}"
                  Content="深度扫描" />
          <Button Margin="0,0,8,0"
                  Padding="14,8"
                  Command="{Binding PreviewPlanCommand}"
                  Content="预演计划" />
          <Button Padding="14,8"
                  Command="{Binding ExecutePlanCommand}"
                  Content="执行计划" />
        </StackPanel>
      </Grid>
    </Border>

    <ItemsControl Grid.Row="1"
                  Margin="0,18,0,18"
                  ItemsSource="{Binding SummaryCards}">
      <ItemsControl.ItemsPanel>
        <ItemsPanelTemplate>
          <UniformGrid Columns="4" />
        </ItemsPanelTemplate>
      </ItemsControl.ItemsPanel>
      <ItemsControl.ItemTemplate>
        <DataTemplate DataType="{x:Type viewModels:SummaryCardViewModel}">
          <Border Margin="0,0,12,0"
                  Padding="16"
                  Background="#FFFDFBF7"
                  BorderBrush="#FFE1D5BC"
                  BorderThickness="1"
                  CornerRadius="14">
            <StackPanel>
              <TextBlock FontSize="13"
                         Foreground="#FF6A5A43"
                         Text="{Binding Title}" />
              <TextBlock Margin="0,6,0,0"
                         FontSize="24"
                         FontWeight="SemiBold"
                         Foreground="#FF2E2A24"
                         Text="{Binding Value}" />
              <TextBlock Margin="0,8,0,0"
                         Foreground="#FF6A5A43"
                         TextWrapping="Wrap"
                         Text="{Binding Subtitle}" />
            </StackPanel>
          </Border>
        </DataTemplate>
      </ItemsControl.ItemTemplate>
    </ItemsControl>

    <TabControl Grid.Row="2"
                Background="#FFFDFBF7"
                BorderBrush="#FFE1D5BC"
                BorderThickness="1">
      <TabItem Header="清理候选">
        <Grid Margin="16">
          <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
          </Grid.RowDefinitions>
          <DataGrid ItemsSource="{Binding Findings}"
                    AutoGenerateColumns="False"
                    CanUserAddRows="False"
                    IsReadOnly="False"
                    HeadersVisibility="Column"
                    GridLinesVisibility="Horizontal"
                    RowBackground="#FFFFFCF8"
                    AlternatingRowBackground="#FFF8F2E8">
            <DataGrid.Columns>
              <DataGridCheckBoxColumn Width="60"
                                      Binding="{Binding IsSelected, Mode=TwoWay}"
                                      Header="选中" />
              <DataGridTextColumn Width="150" Binding="{Binding TierLabel}" Header="风险层级" />
              <DataGridTextColumn Width="130" Binding="{Binding CategoryLabel}" Header="分类" />
              <DataGridTextColumn Width="120" Binding="{Binding SizeText}" Header="大小" />
              <DataGridTextColumn Width="120" Binding="{Binding ActionText}" Header="建议动作" />
              <DataGridTextColumn Width="*" Binding="{Binding Finding.Path}" Header="路径" />
              <DataGridTextColumn Width="280" Binding="{Binding Finding.WhySuggested}" Header="建议原因" />
              <DataGridTextColumn Width="170" Binding="{Binding ModifiedText}" Header="最后修改" />
              <DataGridTemplateColumn Width="180" Header="操作">
                <DataGridTemplateColumn.CellTemplate>
                  <DataTemplate>
                    <StackPanel Orientation="Horizontal">
                      <Button Margin="0,0,8,0"
                              Padding="10,4"
                              Command="{Binding DataContext.OpenPathCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                              CommandParameter="{Binding}"
                              Content="打开位置" />
                      <Button Padding="10,4"
                              Command="{Binding DataContext.IgnoreFindingCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                              CommandParameter="{Binding}"
                              Content="忽略" />
                    </StackPanel>
                  </DataTemplate>
                </DataGridTemplateColumn.CellTemplate>
              </DataGridTemplateColumn>
            </DataGrid.Columns>
          </DataGrid>

          <Border Grid.Row="1"
                  Margin="0,14,0,0"
                  Padding="14"
                  Background="#FFF8F2E8"
                  CornerRadius="12">
            <TextBlock FontFamily="Consolas"
                       TextWrapping="Wrap"
                       Text="{Binding PlanOverview}" />
          </Border>
        </Grid>
      </TabItem>

      <TabItem Header="软件卸载">
        <Grid Margin="16">
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
          </Grid.RowDefinitions>
          <StackPanel Orientation="Horizontal">
            <Button Padding="14,8"
                    Command="{Binding RefreshAppsCommand}"
                    Content="刷新软件列表" />
            <TextBlock Margin="12,0,0,0"
                       VerticalAlignment="Center"
                       Foreground="#FF6A5A43"
                       Text="这里只会调用官方卸载入口，不会直接删除程序目录。" />
          </StackPanel>
          <DataGrid Grid.Row="1"
                    Margin="0,14,0,0"
                    ItemsSource="{Binding InstalledApps}"
                    AutoGenerateColumns="False"
                    CanUserAddRows="False"
                    IsReadOnly="True"
                    RowBackground="#FFFFFCF8"
                    AlternatingRowBackground="#FFF8F2E8">
            <DataGrid.Columns>
              <DataGridTextColumn Width="260" Binding="{Binding DisplayName}" Header="软件名称" />
              <DataGridTextColumn Width="160" Binding="{Binding Publisher}" Header="发布者" />
              <DataGridTextColumn Width="130" Binding="{Binding SizeText}" Header="估计大小" />
              <DataGridTextColumn Width="*" Binding="{Binding InstallLocation}" Header="安装位置" />
              <DataGridTemplateColumn Width="190" Header="操作">
                <DataGridTemplateColumn.CellTemplate>
                  <DataTemplate DataType="{x:Type viewModels:InstalledAppItemViewModel}">
                    <StackPanel Orientation="Horizontal">
                      <Button Margin="0,0,8,0"
                              Padding="10,4"
                              Command="{Binding DataContext.UninstallAppCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                              CommandParameter="{Binding}"
                              Content="启动卸载" />
                      <Button Padding="10,4"
                              Command="{Binding DataContext.OpenPathCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                              CommandParameter="{Binding}"
                              Content="打开位置" />
                    </StackPanel>
                  </DataTemplate>
                </DataGridTemplateColumn.CellTemplate>
              </DataGridTemplateColumn>
            </DataGrid.Columns>
          </DataGrid>
        </Grid>
      </TabItem>

      <TabItem Header="恢复与审计">
        <Grid Margin="16">
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
          </Grid.RowDefinitions>
          <StackPanel Orientation="Horizontal">
            <Button Padding="14,8"
                    Command="{Binding RefreshHistoryCommand}"
                    Content="刷新记录" />
            <TextBlock Margin="12,0,0,0"
                       VerticalAlignment="Center"
                       Foreground="#FF6A5A43"
                       Text="只有进入隔离区的动作支持恢复；审计型清理只保留记录，不保存文件副本。" />
          </StackPanel>
          <DataGrid Grid.Row="1"
                    Margin="0,14,0,0"
                    ItemsSource="{Binding ActionHistory}"
                    AutoGenerateColumns="False"
                    CanUserAddRows="False"
                    IsReadOnly="True"
                    RowBackground="#FFFFFCF8"
                    AlternatingRowBackground="#FFF8F2E8">
            <DataGrid.Columns>
              <DataGridTextColumn Width="200" Binding="{Binding StartedText}" Header="开始时间" />
              <DataGridTextColumn Width="120" Binding="{Binding OperationText}" Header="动作" />
              <DataGridTextColumn Width="110" Binding="{Binding StatusText}" Header="状态" />
              <DataGridTextColumn Width="120" Binding="{Binding FreedText}" Header="释放空间" />
              <DataGridTextColumn Width="*" Binding="{Binding Path}" Header="路径" />
              <DataGridTextColumn Width="240" Binding="{Binding Summary}" Header="说明" />
              <DataGridTemplateColumn Width="180" Header="操作">
                <DataGridTemplateColumn.CellTemplate>
                  <DataTemplate DataType="{x:Type viewModels:ActionRecordItemViewModel}">
                    <StackPanel Orientation="Horizontal">
                      <Button Margin="0,0,8,0"
                              Padding="10,4"
                              Command="{Binding DataContext.OpenPathCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                              CommandParameter="{Binding}"
                              Content="打开位置" />
                      <Button Padding="10,4"
                              Command="{Binding DataContext.RestoreActionCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                              CommandParameter="{Binding}"
                              Content="恢复" />
                    </StackPanel>
                  </DataTemplate>
                </DataGridTemplateColumn.CellTemplate>
              </DataGridTemplateColumn>
            </DataGrid.Columns>
          </DataGrid>
        </Grid>
      </TabItem>

      <TabItem Header="官方入口与趋势">
        <Grid Margin="16">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1.3*" />
            <ColumnDefinition Width="*" />
          </Grid.ColumnDefinitions>

          <GroupBox Header="系统官方处理入口" Margin="0,0,12,0">
            <ListBox ItemsSource="{Binding GuidanceItems}">
              <ListBox.ItemTemplate>
                <DataTemplate DataType="{x:Type models:SystemGuidanceItem}">
                  <Border Margin="0,0,0,10"
                          Padding="12"
                          Background="#FFFFFCF8"
                          BorderBrush="#FFE1D5BC"
                          BorderThickness="1"
                          CornerRadius="10">
                    <DockPanel>
                      <Button DockPanel.Dock="Right"
                              Padding="10,4"
                              Command="{Binding DataContext.OpenGuidanceCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                              CommandParameter="{Binding}"
                              Content="{Binding ActionLabel}" />
                      <StackPanel Margin="0,0,12,0">
                        <TextBlock FontSize="15"
                                   FontWeight="SemiBold"
                                   Text="{Binding Title}" />
                        <TextBlock Margin="0,6,0,0"
                                   Foreground="#FF6A5A43"
                                   TextWrapping="Wrap"
                                   Text="{Binding Description}" />
                      </StackPanel>
                    </DockPanel>
                  </Border>
                </DataTemplate>
              </ListBox.ItemTemplate>
            </ListBox>
          </GroupBox>

          <GroupBox Grid.Column="1" Header="增长最快来源">
            <DataGrid ItemsSource="{Binding GrowthSummaries}"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      IsReadOnly="True"
                      RowBackground="#FFFFFCF8"
                      AlternatingRowBackground="#FFF8F2E8">
              <DataGrid.Columns>
                <DataGridTextColumn Width="*" Binding="{Binding SourceText}" Header="来源" />
                <DataGridTextColumn Width="120" Binding="{Binding CurrentText}" Header="当前" />
                <DataGridTextColumn Width="120" Binding="{Binding PreviousText}" Header="上次" />
                <DataGridTextColumn Width="120" Binding="{Binding DeltaText}" Header="变化" />
              </DataGrid.Columns>
            </DataGrid>
          </GroupBox>
        </Grid>
      </TabItem>
    </TabControl>

    <Border Grid.Row="3"
            Margin="0,18,0,0"
            Padding="14"
            Background="#FFFDFBF7"
            BorderBrush="#FFE1D5BC"
            BorderThickness="1"
            CornerRadius="12">
      <TextBlock Foreground="#FF6A5A43"
                 Text="说明：L1 项默认直接清理并保留审计记录；L2 项优先进入隔离区，便于恢复；L0/L3 项只做解释和引导，不直接删除。" />
    </Border>
  </Grid>
</Window>
